.task-container {
  min-height: 100vh;
  background: var(--bg-color);
  padding: 20rpx 30rpx;
}

/* ── Tab切换 ── */
.tab-switcher {
  display: flex;
  background: white;
  margin-bottom: 24rpx;
  padding: 8rpx;
  gap: 12rpx;
  border-radius: 48rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: 40rpx;
}

.tab-item.active {
  background: var(--primary-color);
  color: white;
  font-weight: 500;
}

/* ── 任务卡片 ── */
.task-card {
  background: white;
  border-radius: 48rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 48rpx rgba(0, 0, 0, 0.06);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.task-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.task-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.status-1 { background: #FFF8E6; color: #FAAD14; }
.status-2 { background: #F0FFF0; color: #52C41A; }
.status-3 { background: #F5F5F5; color: #999; }

.progress-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), var(--primary-dark));
  border-radius: 8rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.task-meta {
  margin-bottom: 16rpx;
}

.task-deadline {
  font-size: 24rpx;
  color: var(--text-light);
}

.task-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.btn-checkin {
  height: 64rpx;
  line-height: 64rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
  font-size: 26rpx;
  border-radius: 32rpx;
  text-align: center;
}

.pending-records {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.record-pending {
  font-size: 24rpx;
  color: var(--warning-color);
}

.record-confirm {
  color: var(--primary-color);
  font-weight: 500;
}

.record-confirmed {
  font-size: 24rpx;
  color: var(--success-color);
}

/* ── 愿望卡片 ── */
.wish-card {
  background: white;
  border-radius: 48rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 48rpx rgba(0, 0, 0, 0.06);
}

.wish-card.achieved {
  opacity: 0.7;
  background: #F9FFF9;
}

.wish-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.wish-category-icon { font-size: 40rpx; }
.wish-info { flex: 1; }

.wish-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.wish-category {
  font-size: 24rpx;
  color: var(--text-light);
}

.wish-status { font-size: 24rpx; }

.wish-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.wish-progress .progress-bar {
  background: #FFE5EC;
}

.wish-progress-fill {
  background: linear-gradient(90deg, #FFD699, #FFB84D) !important;
}

.wish-meta { margin-bottom: 16rpx; }
.wish-date { font-size: 24rpx; color: var(--text-light); }

.wish-actions {
  display: flex;
  gap: 16rpx;
}

.btn-progress, .btn-achieve {
  flex: 1;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  border-radius: 30rpx;
  text-align: center;
}

.btn-progress {
  background: white;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

.btn-achieve {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
}

/* ── 模态框 ── */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.modal-content {
  background: white;
  border-radius: 48rpx 48rpx 0 0;
  padding: 40rpx 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.modal-title { font-size: 34rpx; font-weight: 700; }
.modal-close { font-size: 36rpx; color: var(--text-light); }

.form-group { margin-bottom: 30rpx; }
.form-label { font-size: 28rpx; color: var(--text-secondary); display: block; margin-bottom: 12rpx; }

.form-input {
  background: #F8F8F8;
  border: 2rpx solid var(--border-color);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 88rpx;
}

.radio-group { display: flex; gap: 16rpx; flex-wrap: wrap; }

.radio-item {
  padding: 12rpx 28rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  background: #F8F8F8;
  color: var(--text-secondary);
  border: 2rpx solid var(--border-color);
}

.radio-item.active {
  background: #FFF0F3;
  color: var(--primary-color);
  border-color: var(--primary-color);
}

.btn-submit {
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 50rpx;
  margin-top: 20rpx;
}

/* ── 骨架屏 / 加载 / 空状态 ── */
.skeleton-list { margin-bottom: 24rpx; }
.skeleton-card {
  background: white;
  border-radius: 48rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.skeleton-line { height: 24rpx; background: #F0F0F0; border-radius: 12rpx; }
.w-80 { width: 80%; }
.w-60 { width: 60%; }
.w-40 { width: 40%; }
.h-16 { height: 16rpx; }

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.error-retry {
  margin-top: 24rpx;
  padding: 16rpx 48rpx;
  font-size: 26rpx;
  color: white;
  background: var(--primary-color);
  border-radius: 32rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-title { font-size: 28rpx; color: #666; margin-bottom: 12rpx; }
.empty-desc { font-size: 24rpx; color: #999; }
