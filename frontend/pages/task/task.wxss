.task-container {
  min-height: 100vh;
  background: var(--bg-color);
  padding: 20rpx 30rpx;
}

.task-card {
  background: white;
  border-radius: 48rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 48rpx rgba(0, 0, 0, 0.06);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.task-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.task-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.status-1 { background: #FFF8E6; color: #FAAD14; }
.status-2 { background: #F0FFF0; color: #52C41A; }
.status-3 { background: #F5F5F5; color: #999; }

.progress-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), var(--primary-dark));
  border-radius: 8rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.task-meta {
  margin-bottom: 16rpx;
}

.task-deadline {
  font-size: 24rpx;
  color: var(--text-light);
}

.task-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.btn-checkin {
  height: 64rpx;
  line-height: 64rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
  font-size: 26rpx;
  border-radius: 32rpx;
  text-align: center;
}

.pending-records {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.record-pending {
  font-size: 24rpx;
  color: var(--warning-color);
}

.record-confirm {
  color: var(--primary-color);
  font-weight: 500;
}

.record-confirmed {
  font-size: 24rpx;
  color: var(--success-color);
}

/* Modal */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.modal-content {
  background: white;
  border-radius: 48rpx 48rpx 0 0;
  padding: 40rpx 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.modal-title { font-size: 34rpx; font-weight: 700; }
.modal-close { font-size: 36rpx; color: var(--text-light); }

.form-group { margin-bottom: 30rpx; }
.form-label { font-size: 28rpx; color: var(--text-secondary); display: block; margin-bottom: 12rpx; }

.form-input {
  background: #F8F8F8;
  border: 2rpx solid var(--border-color);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 88rpx;
}

.btn-submit {
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 50rpx;
  margin-top: 20rpx;
}

/* 成就墙 */
.badges-section {
  margin-bottom: 24rpx;
}

.badges-header {
  padding: 16rpx 0;
}

.badges-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.badges-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.badge-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #FFF8E6, #FFF3D6);
  border: 2rpx solid #FFE8A0;
  border-radius: 48rpx;
  padding: 16rpx 24rpx;
  min-width: 200rpx;
}

.badge-icon {
  font-size: 40rpx;
}

.badge-info {
  display: flex;
  flex-direction: column;
}

.badge-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #B8860B;
}

.badge-date {
  font-size: 20rpx;
  color: #A0895A;
}
