.todo-container {
  min-height: 100vh;
  background: var(--bg-color);
}

/* Filter Bar */
.filter-bar {
  display: flex;
  background: white;
  margin: 20rpx 30rpx;
  padding: 8rpx;
  gap: 12rpx;
  border-radius: 48rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  border-radius: 40rpx;
  font-weight: 500;
}

.filter-item.active {
  background: var(--primary-color);
  color: white;
}

/* Todo List */
.todo-list {
  padding: 20rpx 30rpx;
}

.todo-item {
  background: white;
  border-radius: 48rpx;
  padding: 28rpx 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 8rpx 48rpx rgba(0, 0, 0, 0.06);
}

.todo-item.completed {
  opacity: 0.6;
}

.todo-check {
  flex-shrink: 0;
}

.check-box {
  font-size: 40rpx;
  color: var(--text-light);
}

.check-box.checked {
  color: var(--success-color);
}

.todo-content {
  flex: 1;
  min-width: 0;
}

.todo-title {
  font-size: 30rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.todo-item.completed .todo-title {
  text-decoration: line-through;
  color: var(--text-light);
}

.todo-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.todo-priority {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 24rpx;
}

.priority-high {
  background: #FFF0F0;
  color: #FF4D4F;
}

.priority-mid {
  background: #FFF8E6;
  color: #FAAD14;
}

.priority-low {
  background: #F0FFF0;
  color: #52C41A;
}

.todo-deadline {
  font-size: 22rpx;
  color: var(--text-light);
}

.todo-delete {
  flex-shrink: 0;
  padding: 10rpx;
}

.delete-icon {
  font-size: 28rpx;
  color: var(--text-light);
}

