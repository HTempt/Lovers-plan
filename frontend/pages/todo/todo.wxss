/* Modal */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.modal-content {
  background: white;
  border-radius: 48rpx 48rpx 0 0;
  padding: 40rpx 30rpx;
  width: 100%;
  box-sizing: border-box;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
}

.modal-close {
  font-size: 36rpx;
  color: var(--text-light);
  padding: 10rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 12rpx;
}

.form-input {
  background: #F8F8F8;
  border: 2rpx solid var(--border-color);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 88rpx;
}

.radio-group {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.radio-item {
  padding: 12rpx 28rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  background: #F8F8F8;
  color: var(--text-secondary);
  border: 2rpx solid var(--border-color);
}

.radio-item.active {
  background: #FFF0F3;
  color: var(--primary-color);
  border-color: var(--primary-color);
  border-radius: 24rpx;
}

.btn-submit {
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 50rpx;
  margin-top: 20rpx;
}
