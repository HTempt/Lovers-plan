.bind-container {
  min-height: 100vh;
  background: var(--bg-color);
  padding: 0 40rpx;
}

/* Header */
.bind-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
}

.bind-heart {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.bind-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.bind-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* Options */
.bind-options {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.bind-card {
  background: white;
  border-radius: 48rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
  box-shadow: 0 8rpx 48rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s;
}

.bind-card:active {
  transform: scale(0.98);
}

.card-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.create-icon {
  background: linear-gradient(135deg, #FFF0F3, #FFE0E6);
}

.join-icon {
  background: linear-gradient(135deg, #F0F4FF, #E0E8FF);
}

.card-icon {
  font-size: 44rpx;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.card-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.card-arrow {
  font-size: 40rpx;
  color: var(--text-light);
}

/* Back button */
.bind-back {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 30rpx 0;
  color: var(--text-secondary);
  font-size: 28rpx;
}

.back-arrow {
  font-size: 40rpx;
}

/* Invite Section */
.invite-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60rpx;
}

.invite-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 40rpx;
}

.invite-code {
  width: 480rpx;
  height: 160rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  transition: all 0.3s;
}

.invite-code.active {
  background: linear-gradient(135deg, #FFF0F3, #FFE0E6);
  border: 4rpx solid var(--primary-color);
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 129, 0.2);
}

.invite-code:not(.active) {
  background: #F8F8F8;
  border: 2rpx dashed var(--border-color);
}

.code-text {
  font-size: 72rpx;
  font-weight: 800;
  color: var(--primary-dark);
  letter-spacing: 16rpx;
  font-family: 'Courier New', monospace;
}

.code-placeholder {
  font-size: 32rpx;
  color: var(--text-light);
}

.btn-generate {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 50rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 129, 0.3);
}

.invite-tips {
  display: flex;
  gap: 40rpx;
  margin-bottom: 50rpx;
}

.tips-item {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.invite-actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
}

.btn-copy, .btn-share {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  text-align: center;
}

.btn-copy {
  background: white;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

.btn-share {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
}

/* Join Section */
.join-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60rpx;
}

.join-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.join-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 60rpx;
}

.code-input-group {
  margin-bottom: 60rpx;
  width: 100%;
  display: flex;
  justify-content: center;
}

.code-input {
  width: 400rpx;
  height: 120rpx;
  background: white;
  border: 4rpx solid var(--border-color);
  border-radius: 24rpx;
  text-align: center;
  font-size: 64rpx;
  font-weight: 700;
  letter-spacing: 20rpx;
  font-family: 'Courier New', monospace;
  caret-color: var(--primary-color);
}

.code-input:focus {
  border-color: var(--primary-color);
}

.btn-bind {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 50rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 129, 0.3);
}

.btn-bind[disabled] {
  opacity: 0.5;
}
