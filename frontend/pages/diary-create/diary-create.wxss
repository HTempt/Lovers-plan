.create-container {
  min-height: 100vh;
  background: var(--bg-color);
  padding: 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.title-input {
  font-size: 36rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--border-color);
  width: 100%;
  min-height: 80rpx;
}

.content-input {
  width: 100%;
  min-height: 300rpx;
  font-size: 30rpx;
  line-height: 1.6;
  padding: 20rpx 0;
  color: var(--text-primary);
}

/* Media */
.media-grid {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.media-item {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
}

.media-preview {
  width: 100%;
  height: 100%;
}

.media-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  background: rgba(0,0,0,0.5);
  color: white;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 36rpx;
  font-size: 24rpx;
}

.media-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed var(--border-color);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.add-icon {
  font-size: 48rpx;
  color: var(--text-light);
}

.add-text {
  font-size: 24rpx;
  color: var(--text-light);
}

/* Location */
.location-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.location-input {
  flex: 1;
  font-size: 28rpx;
  padding: 24rpx 20rpx;
  background: #F8F8F8;
  border-radius: 24rpx;
  min-height: 80rpx;
}

.location-detect {
  font-size: 26rpx;
  color: var(--primary-color);
  padding: 16rpx;
  flex-shrink: 0;
}

.location-city {
  font-size: 26rpx;
  color: #5B8C5A;
  padding: 16rpx;
  flex-shrink: 0;
}

/* Submit */
.submit-section {
  padding-top: 40rpx;
}

.btn-submit {
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 50rpx;
}

.btn-submit[disabled] {
  opacity: 0.5;
}
