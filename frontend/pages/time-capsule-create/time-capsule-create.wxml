<view class="create-container">
  <!-- 步骤指示 -->
  <view class="step-indicator">
    <view class="step {{step === 1 ? 'active' : step > 1 ? 'done' : ''}}">
      <text class="step-num">1</text>
      <text class="step-label">类型</text>
    </view>
    <view class="step-line {{step >= 2 ? 'active' : ''}}"></view>
    <view class="step {{step === 2 ? 'active' : step > 2 ? 'done' : ''}}">
      <text class="step-num">2</text>
      <text class="step-label">内容</text>
    </view>
    <view class="step-line {{step >= 3 ? 'active' : ''}}"></view>
    <view class="step {{step === 3 ? 'active' : ''}}">
      <text class="step-num">3</text>
      <text class="step-label">时间</text>
    </view>
  </view>

  <!-- 步骤1: 选择类型 -->
  <view class="step-content" wx:if="{{step === 1}}">
    <text class="section-title">选择胶囊类型 💌</text>
    <text class="section-desc">封存当下的爱意，在未来某个时间重新开启</text>

    <view class="type-grid">
      <view class="type-card {{formType === item.value ? 'active' : ''}}"
            wx:for="{{capsuleTypes}}" wx:key="value"
            bindtap="onTypeChange" data-value="{{item.value}}">
        <text class="type-icon">{{item.icon}}</text>
        <text class="type-name">{{item.label}}</text>
        <view class="type-checked" wx:if="{{formType === item.value}}">✓</view>
      </view>
    </view>

    <view class="dual-mode-section">
      <view class="dual-mode-header">
        <text class="dual-mode-label">💑 双人模式</text>
        <switch class="dual-mode-switch" checked="{{dualMode}}" bindchange="onDualModeChange" color="#FF6B81"/>
      </view>
      <text class="dual-mode-desc">双方分别写入内容，全部写入后自动封存</text>
    </view>

    <button class="btn-next" bindtap="goStep2">下一步</button>
  </view>

  <!-- 步骤2: 填写内容 -->
  <view class="step-content" wx:elif="{{step === 2}}">
    <text class="section-title">📝 写下想说的话</text>

    <view class="form-group">
      <input class="title-input" placeholder="给这封信起个标题..." value="{{formTitle}}" bindinput="onTitleInput" />
    </view>

    <view class="form-group">
      <textarea class="content-input" placeholder="写下想对未来的TA说的话..." value="{{formContent}}" bindinput="onContentInput" maxlength="5000" auto-height />
    </view>

    <!-- 媒体选择 -->
    <view class="media-section">
      <view class="media-tools">
        <view class="media-btn" bindtap="chooseImage">
          <text class="media-btn-icon">🖼️</text>
          <text class="media-btn-label">图片</text>
        </view>
        <view class="media-btn" bindtap="chooseVoice">
          <text class="media-btn-icon">🎤</text>
          <text class="media-btn-label">语音</text>
        </view>
        <view class="media-btn" bindtap="chooseVideo">
          <text class="media-btn-icon">🎬</text>
          <text class="media-btn-label">视频</text>
        </view>
      </view>

      <view class="media-grid" wx:if="{{mediaList.length > 0}}">
        <view class="media-item" wx:for="{{mediaList}}" wx:for-index="idx" wx:key="index">
          <image class="media-preview" wx:if="{{item.mediaType === 'image'}}" src="{{item.tempPath}}" mode="aspectFill" />
          <text class="media-type-icon" wx:elif="{{item.mediaType === 'audio'}}">🎤</text>
          <text class="media-type-icon" wx:elif="{{item.mediaType === 'video'}}">🎬</text>
          <text class="media-remove" bindtap="removeMedia" data-index="{{idx}}">✕</text>
        </view>
      </view>
    </view>

    <view class="btn-row">
      <button class="btn-prev" bindtap="prevStep">上一步</button>
      <button class="btn-next" bindtap="goStep3">下一步</button>
    </view>
  </view>

  <!-- 步骤3: 选择开启时间 + 提交 -->
  <view class="step-content" wx:elif="{{step === 3}}">
    <text class="section-title">⏰ 选择开启时间</text>

    <view class="time-grid">
      <view class="time-card {{formOpenDays === item.days ? 'active' : ''}}"
            wx:for="{{openOptions}}" wx:key="days"
            wx:if="{{item.days > 0}}"
            bindtap="onOpenDaysChange" data-days="{{item.days}}">
        <text class="time-label">{{item.label}}</text>
        <view class="time-checked" wx:if="{{formOpenDays === item.days}}">✓</view>
      </view>
    </view>

    <!-- 自定义日期 -->
    <view class="form-group" wx:if="{{showCustomDate}}">
      <text class="form-label">选择日期</text>
      <picker class="date-picker" mode="date" value="{{customDate}}" bindchange="onCustomDateChange">
        <view class="picker-value">{{customDate || '请选择日期'}}</view>
      </picker>
    </view>

    <!-- 预览摘要 -->
    <view class="preview-summary">
      <text class="preview-label">📋 胶囊预览</text>
      <view class="preview-card">
        <text class="preview-type">{{getTypeInfo(formType).icon}} {{getTypeInfo(formType).label}}</text>
        <text class="preview-title">{{formTitle || '（未填写标题）'}}</text>
        <text class="preview-time">🔒 {{showCustomDate ? customDate : (formOpenDays + '天后')}} 可开启</text>
        <text class="preview-dual" wx:if="{{dualMode}}">💑 双人模式</text>
      </view>
    </view>

    <button class="btn-submit" bindtap="handleSubmit" loading="{{submitting}}" disabled="{{submitting}}">
      💌 封存胶囊
    </button>
  </view>
</view>
