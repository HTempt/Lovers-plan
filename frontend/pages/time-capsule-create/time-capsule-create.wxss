.create-container {
  min-height: 100vh;
  background: var(--bg-color);
  padding: 30rpx;
}

/* Step indicator */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0 40rpx;
}

.step {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.step-num {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 50%;
  background: #F0F0F0;
  color: #999;
  font-size: 24rpx;
  font-weight: 600;
}

.step.active .step-num {
  background: var(--primary-color);
  color: white;
}

.step.done .step-num {
  background: #2ED573;
  color: white;
}

.step-label {
  font-size: 24rpx;
  color: var(--text-light);
}

.step.active .step-label {
  color: var(--primary-color);
  font-weight: 500;
}

.step-line {
  width: 60rpx;
  height: 4rpx;
  background: #F0F0F0;
  margin: 0 12rpx;
}

.step-line.active {
  background: var(--primary-color);
}

/* Section */
.step-content {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.section-desc {
  font-size: 26rpx;
  color: var(--text-light);
  display: block;
  margin-bottom: 32rpx;
}

/* Type grid */
.type-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.type-card {
  background: white;
  border-radius: 28rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  border: 2rpx solid var(--border-color);
  position: relative;
  transition: all 0.2s;
}

.type-card.active {
  border-color: var(--primary-color);
  background: #FFF0F3;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 129, 0.15);
}

.type-icon {
  font-size: 56rpx;
  display: block;
  margin-bottom: 12rpx;
}

.type-name {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.type-checked {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: var(--primary-color);
  color: white;
  border-radius: 50%;
  font-size: 20rpx;
}

/* Dual mode */
.dual-mode-section {
  background: white;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.dual-mode-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.dual-mode-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.dual-mode-desc {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 8rpx;
  display: block;
}

/* Form */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 12rpx;
}

.title-input {
  background: white;
  border: 2rpx solid var(--border-color);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  font-size: 32rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 88rpx;
  font-weight: 600;
}

.content-input {
  background: white;
  border: 2rpx solid var(--border-color);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 240rpx;
}

/* Media */
.media-section {
  margin-bottom: 24rpx;
}

.media-tools {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.media-btn {
  flex: 1;
  background: white;
  border: 2rpx dashed var(--border-color);
  border-radius: 20rpx;
  padding: 20rpx;
  text-align: center;
}

.media-btn-icon {
  font-size: 36rpx;
  display: block;
}

.media-btn-label {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}

.media-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.media-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  background: #F8F8F8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.media-preview {
  width: 100%;
  height: 100%;
}

.media-type-icon {
  font-size: 48rpx;
}

.media-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: rgba(0,0,0,0.5);
  color: white;
  border-radius: 50%;
  font-size: 20rpx;
}

/* Buttons */
.btn-row {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-prev {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: white;
  color: var(--text-secondary);
  font-size: 30rpx;
  border-radius: 44rpx;
  border: 2rpx solid var(--border-color);
}

.btn-next, .btn-submit {
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
  width: 100%;
  margin-top: 20rpx;
}

/* Time grid */
.time-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.time-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  text-align: center;
  border: 2rpx solid var(--border-color);
  position: relative;
  overflow: hidden;
  transition: all 0.25s ease;
}

.time-card:active {
  transform: scale(0.96);
}

.time-card.active {
  border-color: var(--primary-color);
  background: linear-gradient(135deg, #FFF0F3, #FFF8FA);
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 129, 0.2);
  transform: translateY(-4rpx);
}

.time-card.active::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--primary-dark));
  border-radius: 24rpx 24rpx 0 0;
}

.time-label {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
  transition: all 0.25s ease;
}

.time-card.active .time-label {
  color: var(--primary-color);
  font-weight: 700;
}

.time-checked {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: var(--primary-color);
  color: white;
  border-radius: 50%;
  font-size: 20rpx;
  font-weight: 700;
  animation: checkPop 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes checkPop {
  0% { transform: scale(0); opacity: 0; }
  60% { transform: scale(1.3); }
  100% { transform: scale(1); opacity: 1; }
}

/* Custom date picker */
.date-picker {
  background: white;
  border: 2rpx solid var(--border-color);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
}

.picker-value {
  color: var(--text-primary);
}

/* Preview */
.preview-summary {
  margin: 32rpx 0;
}

.preview-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 12rpx;
}

.preview-card {
  background: linear-gradient(135deg, #FFF0F3, #FFF5F7);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 2rpx solid #FFD5DD;
}

.preview-type {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 8rpx;
}

.preview-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 12rpx;
}

.preview-time, .preview-dual {
  font-size: 24rpx;
  color: var(--text-light);
  display: block;
  margin-bottom: 4rpx;
}
