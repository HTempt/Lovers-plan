.write-container {
  min-height: 100vh;
  background: var(--bg-color);
  padding: 30rpx;
}

.write-header {
  text-align: center;
  padding: 20rpx 0 32rpx;
}

.write-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.write-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  display: block;
}

.form-group {
  margin-bottom: 24rpx;
}

.content-input {
  background: white;
  border: 2rpx solid var(--border-color);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 300rpx;
}

/* Media */
.media-section {
  margin-bottom: 24rpx;
}

.media-tools {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.media-btn {
  flex: 1;
  background: white;
  border: 2rpx dashed var(--border-color);
  border-radius: 20rpx;
  padding: 20rpx;
  text-align: center;
}

.media-btn-icon {
  font-size: 36rpx;
  display: block;
}

.media-btn-label {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}

.media-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.media-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  background: #F8F8F8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.media-preview {
  width: 100%;
  height: 100%;
}

.media-type-icon {
  font-size: 48rpx;
}

.media-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: rgba(0,0,0,0.5);
  color: white;
  border-radius: 50%;
  font-size: 20rpx;
}

.btn-submit {
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  width: 100%;
  margin-top: 20rpx;
}
