/* ============= 足迹地图页面样式 ============= */

.page-wrap {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F0F6FF;
  overflow: hidden;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: linear-gradient(180deg, #6BA3E8 0%, #B5D0F0 40%, #F0F6FF 70%);
}

.loading-icon {
  font-size: 80rpx;
  animation: bounce 1.5s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 24rpx;
}

.content-scroll {
  flex: 1;
  height: 0;
}

/* ===== 统计 ===== */
.stats-section {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
}

.stat-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 24rpx rgba(74, 144, 217, 0.08);
}

.stat-number {
  font-size: 56rpx;
  font-weight: 800;
  color: #4A90D9;
  display: block;
  line-height: 1.2;
}

.stat-label {
  font-size: 26rpx;
  color: #999999;
  margin-top: 8rpx;
  display: block;
}

/* ===== 地图 ===== */
.map-section {
  margin: 0 32rpx 20rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  height: 600rpx;
}

.map {
  width: 100%;
  height: 100%;
}

.map-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  background: #FFFFFF;
}

.map-empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.map-empty-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #666666;
  margin-bottom: 8rpx;
}

.map-empty-desc {
  font-size: 24rpx;
  color: #CCCCCC;
}

/* ===== 城市排行榜 ===== */
.ranking-section {
  padding: 0 32rpx 20rpx;
}

.ranking-header {
  margin-bottom: 16rpx;
}

.ranking-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
}

.ranking-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ranking-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.ranking-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ranking-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #F0F0F0;
  text-align: center;
  line-height: 44rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #999999;
}

.rank-gold {
  background: #FFE793;
  color: #B8860B;
}

.rank-silver {
  background: #E8E8E8;
  color: #666666;
}

.rank-bronze {
  background: #FFDAB9;
  color: #CD853F;
}

.ranking-city {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.ranking-right {
  display: flex;
  align-items: center;
}

.ranking-count {
  font-size: 26rpx;
  color: #4A90D9;
  font-weight: 500;
}
