.login-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 0 60rpx;
  background: linear-gradient(180deg, #FFD5DC 0%, #FFF0F3 30%, #FFF8F8 100%);
}

.login-header {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding-top: 120rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-heart {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  animation: heartbeat 1.5s ease-in-out infinite;
}

@keyframes heartbeat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.logo-title {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--primary-dark);
  margin-bottom: 20rpx;
}

.logo-subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  letter-spacing: 4rpx;
}

.login-features {
  display: flex;
  justify-content: space-around;
  padding: 60rpx 0;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.feature-icon {
  font-size: 48rpx;
}

.feature-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.login-footer {
  padding-bottom: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-wechat {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
  font-size: 34rpx;
  font-weight: 500;
  border-radius: 50rpx;
  text-align: center;
  padding: 0;
  margin: 0;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 129, 0.3);
}

.btn-wechat::after {
  border: none;
}

.btn-icon {
  font-size: 40rpx;
}

.login-agreement {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 30rpx;
}
