.quiz-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF0F3 0%, var(--bg-color) 40%);
  padding: 30rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: var(--text-light);
  font-size: 28rpx;
}

.quiz-header {
  text-align: center;
  padding: 20rpx 0 32rpx;
}

.quiz-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.quiz-type {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 8rpx;
  display: block;
}

.question-card {
  background: white;
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 48rpx rgba(0,0,0,0.06);
  text-align: center;
}

.question-text {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.6;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.option-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: white;
  border: 2rpx solid var(--border-color);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  transition: all 0.2s;
}

.option-item:active {
  transform: scale(0.98);
}

.option-item.selected {
  border-color: var(--primary-color);
  background: #FFF0F3;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 129, 0.15);
}

.option-key {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: #F0F0F0;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 700;
  color: #666;
  flex-shrink: 0;
}

.option-item.selected .option-key {
  background: var(--primary-color);
  color: white;
}

.option-text {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.waiting-section {
  text-align: center;
  padding: 60rpx 0;
}

.waiting-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.waiting-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.result-section {
  margin-bottom: 40rpx;
}

.result-header {
  text-align: center;
  padding: 40rpx;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
}

.result-header.matched {
  background: linear-gradient(135deg, #FFF0F3, #FFE5EC);
}

.result-header.unmatched {
  background: linear-gradient(135deg, #F0F0F0, #F8F8F8);
}

.result-icon {
  font-size: 72rpx;
  display: block;
  margin-bottom: 12rpx;
}

.result-score {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--text-primary);
  display: block;
}

.result-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  display: block;
}

.result-detail {
  background: white;
  border-radius: 24rpx;
  padding: 28rpx;
}

.result-question {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 20rpx;
}

.result-answers {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.result-answer-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.result-answer-label {
  font-size: 24rpx;
  color: var(--text-light);
}

.result-answer-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  padding: 6rpx 20rpx;
  border-radius: 16rpx;
}

.result-answer-value.selected {
  background: #FFF0F3;
  color: var(--primary-color);
}

.result-answer-value.matched {
  background: #E8F8E8;
  color: #2ED573;
}

.result-answer-value.unmatched {
  background: #FFF0F0;
  color: #FF6B6B;
}

.result-growth {
  text-align: center;
  margin-top: 20rpx;
  padding: 12rpx;
  background: #F0FAF0;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #4A7A48;
  font-weight: 500;
}

.btn-submit {
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
}

.error-section {
  text-align: center;
  padding: 100rpx 0;
}

.error-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.error-detail {
  font-size: 24rpx;
  color: var(--text-light);
  display: block;
  margin-bottom: 24rpx;
}

.btn-retry {
  height: 72rpx;
  line-height: 72rpx;
  background: var(--primary-color);
  color: white;
  font-size: 28rpx;
  border-radius: 36rpx;
  width: 240rpx;
}
