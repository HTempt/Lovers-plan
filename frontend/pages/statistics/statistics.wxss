.stats-container {
  min-height: 100vh;
  background: var(--bg-color);
}

.hero-section {
  padding: 40rpx 30rpx;
}

.hero-card {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  border-radius: 48rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 48rpx rgba(0, 0, 0, 0.06);
}

.hero-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-bottom: 16rpx;
}

.hero-number {
  font-size: 96rpx;
  font-weight: 800;
  color: white;
  line-height: 1;
}

.hero-unit {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 8rpx;
}

.stats-section {
  padding: 20rpx 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 20rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-card {
  background: white;
  border-radius: 48rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 8rpx 48rpx rgba(0, 0, 0, 0.06);
}

.stat-number {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--primary-color);
  display: block;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* Reuse existing styles */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: var(--text-secondary);
  font-size: 28rpx;
}

.content-scroll {
  height: 100vh;
}
