/* ============= 双人岛 - 首页样式 ============= */

/* 全局容器 */
.page-wrap {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #FFF8F8;
  overflow: hidden;
}

/* ===== 自定义导航栏 ===== */
.custom-nav {
  background: transparent;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  height: 88rpx;
}

.nav-left { display: flex; align-items: center; }

.nav-date {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.nav-date-wrap {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.nav-lunar {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

.nav-right { display: flex; align-items: center; gap: 16rpx; }

.nav-setting {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 700;
  letter-spacing: 2rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
}

/* ===== 加载/错误状态 ===== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: linear-gradient(180deg, #FF7A90 0%, #FFB7C5 40%, #FFF8F8 70%);
}

.loading-heart {
  font-size: 80rpx;
  animation: heartBeat 1.2s ease-in-out infinite;
}

@keyframes heartBeat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 24rpx;
}

.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: #FFF8F8;
}

.error-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.error-text { font-size: 28rpx; color: #999999; }

/* ===== 内容滚动容器 ===== */
.content-scroll {
  flex: 1;
  height: 0;
  background: #FFF8F8;
}

/* ===== Hero 区域 ===== */
.hero-section {
  padding: 0 0 10rpx 0;
  background: linear-gradient(180deg, #FF7A90 0%, #FFB7C5 50%, #FFF8F8 100%);
  padding-top: calc(88rpx + 30rpx);
  min-height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-bg {
  width: 100%;
  padding: 30rpx 48rpx;
  display: flex;
  justify-content: center;
}

.hero-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.hero-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(255, 107, 129, 0.3);
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.hero-day-wrap {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.hero-day-number {
  font-size: 112rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.1;
  text-shadow: 0 4rpx 20rpx rgba(255, 107, 129, 0.3);
}

.hero-day-unit {
  font-size: 40rpx;
  font-weight: 500;
  color: #D44A5E;
}

.hero-date {
  font-size: 24rpx;
  color: #D44A5E;
  margin-bottom: 6rpx;
}

.hero-quote {
  font-size: 26rpx;
  color: #D44A5E;
  font-style: italic;
  letter-spacing: 2rpx;
  background: rgba(255, 255, 255, 0.6);
  padding: 8rpx 32rpx;
  border-radius: 30rpx;
  max-width: 90%;
  text-align: center;
  line-height: 1.6;
  transition: opacity 0.2s;
}

.hero-quote:active {
  opacity: 0.7;
}

/* ===== 通用模块标题 ===== */
.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #3D3D3D;
}

/* ===== 心动语录轮播 ===== */

/* ===== 状态双人卡 ===== */
.status-dual-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 48rpx;
  padding: 24rpx 32rpx;
  margin: 0 32rpx 20rpx;
  box-shadow: 0 8rpx 48rpx rgba(0, 0, 0, 0.06);
}

.status-person {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex: 1;
}

.status-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #FFE5EC;
}

.status-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.status-name { font-size: 24rpx; color: #666666; font-weight: 500; }

.status-tag {
  font-size: 22rpx;
  color: #999999;
  background: #F5F5F5;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  white-space: nowrap;
}

.status-tag-active {
  color: #FF6B81;
  background: #FFE5EC;
}

.status-duration { font-size: 20rpx; color: #BBBBBB; }

.status-heart-connector {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
}

.status-heart-icon {
  font-size: 40rpx;
}

.heartbeat-anim {
  animation: heartBeatStrong 1.4s ease-in-out infinite;
}

@keyframes heartBeatStrong {
  0%, 100% { transform: scale(1); opacity: 0.8; }
  15% { transform: scale(1.25); opacity: 1; }
  30% { transform: scale(1); opacity: 0.9; }
  45% { transform: scale(1.2); opacity: 1; }
  60% { transform: scale(1); opacity: 0.9; }
}

/* ===== 双列卡片行 ===== */
.dual-card-row {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 16rpx;
}

.dual-card {
  flex: 1;
  min-width: 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.dual-card-header {
  padding: 10rpx 12rpx 2rpx;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.dual-card-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #3D3D3D;
}

/* ===== 那天的我们（紧凑卡片列表） ===== */
.memory-compact-list {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 6rpx 12rpx 12rpx;
}

.memory-compact-item {
  display: flex;
  gap: 10rpx;
  padding: 8rpx 10rpx;
  border-radius: 16rpx;
  align-items: center;
}

.memory-compact-img {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.memory-compact-thumb {
  width: 100%;
  height: 100%;
}

.memory-compact-img-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  background: #FFF5F5;
}

.memory-compact-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.memory-compact-offset {
  font-size: 18rpx;
  color: #FF6B81;
  font-weight: 600;
}

.memory-compact-title {
  font-size: 20rpx;
  color: #3D3D3D;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.memory-compact-date {
  font-size: 18rpx;
  color: #BBB;
}

.memory-diary-bg { background: #FFF5F0; }
.memory-anni-bg { background: #FFF0F0; }
.memory-wish-bg { background: #FFF8EE; }
.memory-task-bg { background: #F0FAF0; }

/* ===== 爱情树（紧凑卡片） ===== */
.love-tree-compact {
  padding: 6rpx 18rpx 16rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.love-tree-compact-top {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.love-tree-compact-icon {
  font-size: 32rpx;
}

.love-tree-compact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 1rpx;
}

.love-tree-compact-level {
  font-size: 22rpx;
  font-weight: 700;
  color: #4A7A48;
}

.love-tree-compact-name {
  font-size: 18rpx;
  color: #6B9A6A;
}

.love-tree-compact-sign {
  background: #E8F3E2;
  padding: 4rpx 10rpx;
  border-radius: 14rpx;
}

.love-tree-compact-sign-text {
  font-size: 18rpx;
  color: #4A7A48;
  font-weight: 600;
}

.love-tree-compact-progress {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.love-tree-compact-bar {
  flex: 1;
  height: 8rpx;
  background: #E8E8E8;
  border-radius: 4rpx;
  overflow: hidden;
}

.love-tree-compact-fill {
  height: 100%;
  background: linear-gradient(90deg, #8BC88A, #5EAB5B);
  border-radius: 4rpx;
}

.love-tree-compact-text {
  font-size: 18rpx;
  color: #6B9A6A;
  font-weight: 600;
  flex-shrink: 0;
}

.love-tree-compact-hint {
  font-size: 18rpx;
  color: #6B9A6A;
  opacity: 0.7;
}

/* ===== 今日提醒（双列网格） ===== */
.reminder-section {
  padding: 0 32rpx 16rpx;
}

.reminder-grid {
  display: flex;
  gap: 12rpx;
}

.reminder-card {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.reminder-body {
  padding: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.reminder-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.reminder-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.reminder-title {
  font-size: 22rpx;
  font-weight: 700;
  color: #333;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  flex: 1;
}

.reminder-countdown-wrap {
  display: flex;
  align-items: baseline;
  gap: 3rpx;
  margin-top: auto;
}

.reminder-countdown-num {
  font-size: 32rpx;
  font-weight: 800;
  color: #FF6B81;
  line-height: 1;
}

.reminder-countdown-unit {
  font-size: 18rpx;
  color: #FF9EB0;
}

.reminder-progress-wrap {
  display: flex;
  flex-direction: column;
  gap: 5rpx;
  margin-top: auto;
}

.reminder-progress-bar {
  height: 6rpx;
  background: #F0F0F0;
  border-radius: 3rpx;
  overflow: hidden;
}

.reminder-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF9EB0, #FF6B81);
  border-radius: 3rpx;
}

.reminder-wish-fill {
  background: linear-gradient(90deg, #FFD699, #FFB84D);
}

/* 时光胶囊提醒卡片 */
.reminder-capsule .reminder-icon {
  font-size: 32rpx;
}

.reminder-progress-text {
  font-size: 18rpx;
  color: #999;
}

.reminder-desc {
  font-size: 20rpx;
  color: #999;
  margin-top: auto;
}

.feed-section {
  padding: 0 32rpx 20rpx;
}

.feed-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feed-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 22rpx 26rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.feed-icon-wrap {
  width: 68rpx;
  height: 68rpx;
  background: linear-gradient(135deg, #FFF5F7, #FFE8EC);
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.feed-icon {
  font-size: 36rpx;
}

.feed-body {
  flex: 1;
  min-width: 0;
}

.feed-title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.feed-desc {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.feed-time {
  font-size: 22rpx;
  color: #CCCCCC;
  display: block;
}

.feed-arrow {
  font-size: 32rpx;
  color: #DDDDDD;
  flex-shrink: 0;
}

.feed-more {
  display: flex;
  justify-content: center;
  padding: 20rpx 0 4rpx;
}

.feed-more-text {
  font-size: 24rpx;
  color: #FF6B81;
  font-weight: 500;
}
.feed-no-more-text {
  font-size: 24rpx;
  color: #DDDDDD;
}

.feed-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.feed-empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.feed-empty-text {
  font-size: 26rpx;
  color: #CCCCCC;
}

/* ===== 🕰 时光机（紧凑卡片） ===== */
.dual-card-subtitle {
  font-size: 20rpx;
  color: #AAA;
  font-weight: 400;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
}

.time-machine-compact {
  padding: 10rpx 14rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  cursor: pointer;
}

.time-machine-compact:active {
  opacity: 0.7;
}

.tm-image-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.tm-thumb {
  width: 100%;
  height: 100%;
}

.tm-text-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  background: #FFF0F3;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tm-emoj {
  font-size: 40rpx;
}

.tm-info {
  flex: 1;
  min-width: 0;
}

.tm-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #3D3D3D;
  display: block;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  margin-bottom: 4rpx;
}

.tm-date {
  font-size: 22rpx;
  color: #999;
  display: block;
}

.tm-arrow {
  font-size: 32rpx;
  color: #CCC;
  flex-shrink: 0;
}

/* ===== 🌏 情侣足迹 ===== */
.lc-footprint {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 6rpx 12rpx 14rpx;
  gap: 8rpx;
  overflow: hidden;
}

.lc-footprint-sub {
  font-size: 20rpx;
  color: #999;
  flex-shrink: 0;
}

.lc-footprint-tags {
  display: flex;
  align-items: center;
  gap: 6rpx;
  overflow: hidden;
  min-width: 0;
}

.lc-city-tag {
  font-size: 20rpx;
  color: #FF6B81;
  background: #FFF0F3;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

/* ===== 🎯 愿望进度 ===== */
.lc-wish {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 10rpx 14rpx 16rpx;
}

.lc-wish-bar {
  height: 10rpx;
  background: #F0F0F0;
  border-radius: 5rpx;
  overflow: hidden;
}

.lc-wish-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFD699, #FFB84D);
  border-radius: 5rpx;
}

.lc-wish-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.lc-wish-text {
  font-size: 24rpx;
  color: #FFB84D;
  font-weight: 600;
}

/* ===== ❤️ 恋爱里程碑 ===== */
.lc-milestone {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 14rpx 16rpx;
}

.lc-milestone-count-wrap {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.lc-milestone-num {
  font-size: 48rpx;
  font-weight: 800;
  color: #FF6B81;
  line-height: 1;
}

.lc-milestone-unit {
  font-size: 24rpx;
  color: #FF9EB0;
  font-weight: 500;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 200rpx 60rpx;
  background: #FFF8F8;
}

.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-title { font-size: 28rpx; color: #666666; margin-bottom: 12rpx; }
.empty-desc { font-size: 24rpx; color: #999999; margin-bottom: 40rpx; }
