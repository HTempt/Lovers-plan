/* ============= 双人岛 - 首页样式 ============= */

/* 全局容器 */
.page-wrap {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #FFF8F8;
  overflow: hidden;
}

/* ===== 自定义导航栏 ===== */
.custom-nav {
  background: transparent;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  height: 88rpx;
}

.nav-left { display: flex; align-items: center; }

.nav-date {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.nav-date-wrap {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.nav-lunar {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

.nav-right { display: flex; align-items: center; gap: 16rpx; }

.nav-setting {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 700;
  letter-spacing: 2rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
}

/* ===== 加载/错误状态 ===== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: linear-gradient(180deg, #FF7A90 0%, #FFB7C5 40%, #FFF8F8 70%);
}

.loading-heart {
  font-size: 80rpx;
  animation: heartBeat 1.2s ease-in-out infinite;
}

@keyframes heartBeat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 24rpx;
}

.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: #FFF8F8;
}

.error-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.error-text { font-size: 28rpx; color: #999999; }

/* ===== 内容滚动容器 ===== */
.content-scroll {
  flex: 1;
  height: 0;
  background: #FFF8F8;
}

/* ===== Hero 区域 ===== */
.hero-section {
  padding: 0 0 10rpx 0;
  background: linear-gradient(180deg, #FF7A90 0%, #FFB7C5 50%, #FFF8F8 100%);
  padding-top: calc(88rpx + 30rpx);
  min-height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-bg {
  width: 100%;
  padding: 30rpx 48rpx;
  display: flex;
  justify-content: center;
}

.hero-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.hero-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(255, 107, 129, 0.3);
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.hero-day-wrap {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.hero-day-number {
  font-size: 112rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.1;
  text-shadow: 0 4rpx 20rpx rgba(255, 107, 129, 0.3);
}

.hero-day-unit {
  font-size: 40rpx;
  font-weight: 500;
  color: #D44A5E;
}

.hero-date {
  font-size: 24rpx;
  color: #D44A5E;
  margin-bottom: 6rpx;
}

.hero-quote {
  font-size: 26rpx;
  color: #D44A5E;
  font-style: italic;
  letter-spacing: 2rpx;
  background: rgba(255, 255, 255, 0.6);
  padding: 8rpx 32rpx;
  border-radius: 30rpx;
  max-width: 90%;
  text-align: center;
  line-height: 1.6;
  transition: opacity 0.2s;
}

.hero-quote:active {
  opacity: 0.7;
}

/* ===== 状态双人卡 ===== */
.status-dual-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 48rpx;
  padding: 24rpx 32rpx;
  margin: 0 32rpx 20rpx;
  box-shadow: 0 8rpx 48rpx rgba(0, 0, 0, 0.06);
}

.status-person {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex: 1;
}

.status-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #FFE5EC;
}

.status-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.status-name { font-size: 24rpx; color: #666666; font-weight: 500; }

.status-tag {
  font-size: 22rpx;
  color: #999999;
  background: #F5F5F5;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  white-space: nowrap;
}

.status-tag-active {
  color: #FF6B81;
  background: #FFE5EC;
}

.status-duration { font-size: 20rpx; color: #BBBBBB; }

.status-heart-connector {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
}

.status-heart-icon {
  font-size: 40rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(1.15); opacity: 1; }
}

/* ===== 爱情树（含签到状态） ===== */
.love-tree-section {
  padding: 0 32rpx 20rpx;
}

.love-tree-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: linear-gradient(135deg, #E8F3E2, #D4E8CC);
  border-radius: 32rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.love-tree-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.love-tree-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.love-tree-icon {
  font-size: 48rpx;
}

.love-tree-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.love-tree-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #3D6B3C;
}

.love-tree-level-name {
  font-size: 22rpx;
  color: #5B8C5A;
}

.love-tree-sign-status {
  background: rgba(255, 255, 255, 0.7);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.love-tree-sign-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #3D6B3C;
}

.love-tree-progress-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.love-tree-progress-bar {
  flex: 1;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 8rpx;
  overflow: hidden;
}

.love-tree-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #7BB77A, #4A8B47);
  border-radius: 8rpx;
}

.love-tree-progress-text {
  font-size: 24rpx;
  color: #5B8C5A;
  font-weight: 600;
  flex-shrink: 0;
}

.love-tree-footer {
  display: flex;
  align-items: center;
}

.love-tree-sign-hint {
  font-size: 22rpx;
  color: #5B8C5A;
  opacity: 0.8;
}

/* ===== 今日提醒 ===== */
.reminder-section {
  padding: 0 32rpx 16rpx;
}

.reminder-scroll-x {
  display: flex;
  gap: 20rpx;
}

.reminder-card {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.reminder-accent {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.accent-anni { background: linear-gradient(135deg, #FFE5EC, #FFD5DC); }
.accent-task { background: linear-gradient(135deg, #EEF7FF, #D6EEFF); }
.accent-todo { background: linear-gradient(135deg, #FFF3E8, #FFE8D6); }

.reminder-accent-icon { font-size: 40rpx; }

.reminder-body {
  padding: 16rpx 20rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.reminder-body-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.reminder-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #333333;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.reminder-countdown-wrap {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.reminder-countdown-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #FF6B81;
  line-height: 1;
}

.reminder-countdown-unit {
  font-size: 24rpx;
  color: #FF6B81;
  font-weight: 500;
}

.reminder-progress-wrap {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.reminder-progress-bar {
  height: 10rpx;
  background: #F0F0F0;
  border-radius: 5rpx;
  overflow: hidden;
}

.reminder-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #6EC3FF, #4DA8E8);
  border-radius: 5rpx;
}

.reminder-progress-text {
  font-size: 22rpx;
  color: #999999;
}

.reminder-desc {
  font-size: 24rpx;
  color: #999999;
}

/* ===== 岛屿动态 ===== */
.feed-section {
  padding: 0 32rpx 20rpx;
}

.feed-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.feed-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
}

.feed-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feed-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.feed-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  background: #FFF5F7;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.feed-icon {
  font-size: 36rpx;
}

.feed-body {
  flex: 1;
  min-width: 0;
}

.feed-title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.feed-desc {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.feed-time {
  font-size: 22rpx;
  color: #CCCCCC;
  display: block;
}

.feed-arrow {
  font-size: 32rpx;
  color: #DDDDDD;
  flex-shrink: 0;
}

.feed-loading {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
}

.feed-loading-text {
  font-size: 24rpx;
  color: #CCCCCC;
}

.feed-no-more {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
}

.feed-no-more-text {
  font-size: 24rpx;
  color: #DDDDDD;
}

.feed-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.feed-empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.feed-empty-text {
  font-size: 26rpx;
  color: #CCCCCC;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 200rpx 60rpx;
  background: #FFF8F8;
}

.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-title { font-size: 28rpx; color: #666666; margin-bottom: 12rpx; }
.empty-desc { font-size: 24rpx; color: #999999; margin-bottom: 40rpx; }
