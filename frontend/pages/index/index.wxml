<view class="page-wrap">
  <!-- 自定义导航栏 -->
  <view class="custom-nav">
    <view class="nav-status-bar" style="height: {{statusBarHeight}}px;"></view>
    <view class="nav-content">
      <view class="nav-left">
        <view class="nav-date-wrap">
          <text class="nav-date">{{currentDate}}</text>
          <text class="nav-lunar" wx:if="{{lunarDate}}">{{lunarDate}}</text>
        </view>
      </view>
      <view class="nav-right">
        <text class="nav-setting" bindtap="goToProfile">···</text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-heart">❤️</view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-wrap" wx:elif="{{error}}">
    <text class="error-icon">🥺</text>
    <text class="error-text">加载失败，下拉刷新试试</text>
  </view>

  <!-- 首页内容主体 -->
  <scroll-view class="content-scroll" scroll-y enhanced
    enable-back-to-top refresher-enabled
    bindrefresherrefresh="onRefresh"
    bindscrolltolower="loadMoreFeed" wx:elif="{{hasCouple}}">

    <!-- ===== Hero 区域：恋爱天数 ===== -->
    <view class="hero-section">
      <view class="hero-bg">
        <view class="hero-content">
          <text class="hero-label" wx:if="{{isMarried}}">我们结婚啦</text>
          <text class="hero-label" wx:else>我们恋爱啦</text>
          <view class="hero-day-wrap">
            <text class="hero-day-number" wx:if="{{isMarried}}">{{marriedDays}}</text>
            <text class="hero-day-number" wx:else>{{loveDays}}</text>
            <text class="hero-day-unit">天</text>
          </view>
          <text class="hero-quote" bindtap="onSentenceTap" data-page="{{dailySentence.page || ''}}">"{{dailySentence.text || dailySentence}}"</text>
        </view>
      </view>
    </view>



    <!-- ===== 双人状态卡片 ===== -->
    <view class="status-dual-card">
      <view class="status-person" bindtap="setMyStatus">
        <image class="status-avatar" src="{{myAvatar || '/images/icon/user-girl.png'}}" binderror="onMyAvatarError" />
        <view class="status-info">
          <text class="status-name">我</text>
          <view class="status-tag {{myStatus ? 'status-tag-active' : ''}}">
            <text>{{myStatus || '点击设置'}}</text>
          </view>
          <text class="status-duration" wx:if="{{myStatusDuration}}">{{myStatusDuration}}</text>
        </view>
      </view>
      <view class="status-heart-connector">
        <text class="status-heart-icon heartbeat-anim">💗</text>
      </view>
      <view class="status-person status-person-right">
        <image class="status-avatar" src="{{partnerAvatar || '/images/icon/user-girl.png'}}" binderror="onPartnerAvatarError" />
        <view class="status-info">
          <text class="status-name">{{partnerName}}</text>
          <view class="status-tag {{partnerStatus ? 'status-tag-active' : ''}}">
            <text>{{partnerStatus || '暂无状态'}}</text>
          </view>
          <text class="status-duration" wx:if="{{partnerStatusDuration}}">{{partnerStatusDuration}}</text>
        </view>
      </view>
    </view>

    <!-- ===== 双列卡片行：那天的我们 + 爱情树 ===== -->
    <!-- 仅当至少一个模块有内容时展示 -->
    <view class="dual-card-row" wx:if="{{(memories && memories.length > 0) || loveTree}}">
      <!-- 左侧：📷 那天的我们 -->
      <view class="dual-card dual-card-left" wx:if="{{memories && memories.length > 0}}">
        <view class="dual-card-header">
          <text class="dual-card-title">📷 那天的我们</text>
        </view>
        <view class="memory-compact-list">
          <view class="memory-compact-item {{item.type === 'diary' ? 'memory-diary-bg' : ''}} {{item.type === 'anniversary' ? 'memory-anni-bg' : ''}} {{item.type === 'wish' ? 'memory-wish-bg' : ''}} {{item.type === 'task' ? 'memory-task-bg' : ''}}"
                wx:for="{{memories}}" wx:key="index" wx:for-item="mem"
                bindtap="onMemoryTap" data-type="{{mem.type}}" data-refid="{{mem.refId}}">
            <view class="memory-compact-img" wx:if="{{mem.image}}">
              <image class="memory-compact-thumb" src="{{mem.image}}" mode="aspectFill" />
            </view>
            <view class="memory-compact-img memory-compact-img-placeholder" wx:else>
              <text>{{mem.type === 'anniversary' ? '❤️' : mem.type === 'wish' ? '✨' : mem.type === 'task' ? '🎯' : '📝'}}</text>
            </view>
            <view class="memory-compact-info">
              <text class="memory-compact-offset">{{mem.offsetLabel}}</text>
              <text class="memory-compact-title">{{mem.title}}</text>
              <text class="memory-compact-date">{{mem.sourceDate}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 右侧：🌱 爱情树 -->
      <view class="dual-card dual-card-right" wx:if="{{loveTree}}">
        <view class="dual-card-header">
          <text class="dual-card-title">🌱 爱情树</text>
        </view>
        <view class="love-tree-compact" bindtap="goToLoveTree">
          <view class="love-tree-compact-top">
            <text class="love-tree-compact-icon">{{loveTree.levelIcon || '🌱'}}</text>
            <view class="love-tree-compact-info">
              <text class="love-tree-compact-level">Lv{{loveTree.level}}</text>
              <text class="love-tree-compact-name">{{loveTree.levelName}}</text>
            </view>
            <view class="love-tree-compact-sign" wx:if="{{signedInToday}}">
              <text class="love-tree-compact-sign-text">已签到 ✓</text>
            </view>
          </view>
          <view class="love-tree-compact-progress">
            <view class="love-tree-compact-bar">
              <view class="love-tree-compact-fill" style="width: {{loveTree.progress}}%;"></view>
            </view>
            <text class="love-tree-compact-text">{{loveTree.growthValue}} / {{loveTree.nextThreshold}}</text>
          </view>
          <text class="love-tree-compact-hint" wx:if="{{signedInToday}}">今日签到 +2 · 连续 {{signInStreak}} 天</text>
          <text class="love-tree-compact-hint" wx:else>每日访问自动签到 🌱</text>
        </view>
      </view>
    </view>

    <!-- ===== 时光胶囊入口 ===== -->
    <view class="capsule-row" wx:if="{{capsule}}" bindtap="goToCapsule">
      <view class="capsule-row-icon">💌</view>
      <view class="capsule-row-body">
        <text class="capsule-row-title">时光胶囊</text>
        <text class="capsule-row-desc">封存此刻的爱意，寄往未来</text>
      </view>
      <view class="capsule-row-right">
        <text class="capsule-row-badge" wx:if="{{capsule.openableCount > 0}}">{{capsule.openableCount}} 封可开启</text>
        <text class="capsule-row-arrow">›</text>
      </view>
    </view>

    <!-- ===== 今日提醒（双列卡片） ===== -->
    <view class="reminder-section" wx:if="{{reminders && reminders.length > 0}}">
      <view class="section-header">
        <text class="section-title">💌 今日提醒</text>
      </view>
      <view class="reminder-grid">
        <view class="reminder-card {{item.type === 'anniversary' ? 'reminder-anni' : ''}} {{item.type === 'task' ? 'reminder-task' : ''}} {{item.type === 'wish' ? 'reminder-wish' : ''}}"
              wx:for="{{reminders}}" wx:key="index"
              bindtap="onReminderTap" data-page="{{item.page}}" data-id="{{item.id}}">
          <view class="reminder-body">
            <view class="reminder-header">
              <text class="reminder-icon">{{item.icon}}</text>
              <text class="reminder-title">{{item.title}}</text>
            </view>
            <view wx:if="{{item.type === 'anniversary'}}" class="reminder-countdown-wrap">
              <text class="reminder-countdown-num">{{item.daysLeft}}</text>
              <text class="reminder-countdown-unit">天后</text>
            </view>
            <view wx:elif="{{item.type === 'task' && item.progressValue >= 0}}" class="reminder-progress-wrap">
              <view class="reminder-progress-bar">
                <view class="reminder-progress-fill" style="width: {{item.progressValue}}%;"></view>
              </view>
              <text class="reminder-progress-text">{{item.desc}}</text>
            </view>
            <view wx:elif="{{item.type === 'wish' && item.progressValue >= 0}}" class="reminder-progress-wrap">
              <view class="reminder-progress-bar">
                <view class="reminder-progress-fill reminder-wish-fill" style="width: {{item.progressValue}}%;"></view>
              </view>
              <text class="reminder-progress-text">{{item.desc}}</text>
            </view>
            <text wx:else class="reminder-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ===== 岛屿动态（最多3条 + 查看更多） ===== -->
    <view class="feed-section" wx:if="{{!feedLoading}}">
      <view class="section-header">
        <text class="section-title">🌊 岛屿动态</text>
      </view>

      <view class="feed-list">
        <view class="feed-item" wx:for="{{displayFeed}}" wx:key="id"
              bindtap="onFeedItemTap" data-item="{{item}}">
          <view class="feed-icon-wrap">
            <text class="feed-icon">{{item.icon || '📌'}}</text>
          </view>
          <view class="feed-body">
            <text class="feed-title-text">{{item.title}}</text>
            <text class="feed-desc" wx:if="{{item.description}}">{{item.description}}</text>
            <text class="feed-time">{{item._timeDisplay}}</text>
          </view>
          <text class="feed-arrow">›</text>
        </view>
      </view>

      <view class="feed-more" bindtap="goToFeedPage" wx:if="{{feedHasMore}}">
        <text class="feed-more-text">查看更多 ›</text>
      </view>

      <view class="feed-empty" wx:elif="{{(!activityFeed || activityFeed.length === 0) && !loading}}">
        <text class="feed-empty-icon">🏝️</text>
        <text class="feed-empty-text">还没有动态，开始你们的第一个记录吧</text>
      </view>
    </view>
  </scroll-view>

  <!-- 未绑定状态 -->
  <view class="empty-state" wx:elif="{{!hasCouple && !loading}}">
    <text class="empty-icon">💔</text>
    <text class="empty-title">还没有绑定另一半</text>
    <text class="empty-desc">邀请你的TA一起来双人岛吧</text>
    <button class="btn-primary" bindtap="goToBind">去绑定</button>
  </view>
</view>
