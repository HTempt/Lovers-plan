<view class="diary-container">
  <!-- 视图切换 -->
  <view class="view-switcher">
    <view class="switch-item {{currentView === 'timeline' ? 'active' : ''}}" bindtap="switchView" data-view="timeline">时间轴</view>
    <view class="switch-item {{currentView === 'album' ? 'active' : ''}}" bindtap="switchView" data-view="album">相册</view>
  </view>

  <!-- 时间轴视图 -->
  <view class="timeline-view" wx:if="{{currentView === 'timeline'}}">
    <view class="timeline-list">
      <view class="timeline-item" wx:for="{{timeline}}" wx:key="id">
        <view class="timeline-dot"></view>
        <view class="timeline-card">
          <view class="timeline-date">{{item.createTime}}</view>
          <text class="timeline-title">{{item.title}}</text>
          <text class="timeline-content" wx:if="{{item.content}}">{{item.content}}</text>
          <text class="timeline-location" wx:if="{{item.location}}">📍 {{item.location}}</text>
          <!-- 情绪标签 -->
          <text class="timeline-mood" wx:if="{{item.mood}}">😊 {{item.mood}}</text>
          <view class="timeline-media" wx:if="{{item.mediaList && item.mediaList.length > 0}}">
            <image class="media-thumb" wx:for="{{item.mediaList}}" wx:key="id"
                   src="{{item.fileUrl}}" mode="aspectFill"
                   bindtap="previewImage" data-url="{{item.fileUrl}}"
                   wx:if="{{item.mediaType === 'image'}}" />
          </view>
          <view class="timeline-actions">
            <text class="action-delete" bindtap="handleDelete" data-id="{{item.id}}">删除</text>
          </view>
        </view>
      </view>
    </view>

    <view class="load-more" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    <view class="load-more" wx:elif="{{!hasMore && timeline.length > 0}}">
      <text>没有更多了</text>
    </view>

    <view class="empty-state" wx:if="{{timeline.length === 0 && !loading}}">
      <text class="empty-icon">📖</text>
      <text class="empty-title">还没有日记</text>
      <text class="empty-desc">点击下方按钮记录美好时刻吧</text>
    </view>
  </view>

  <!-- 相册视图 -->
  <view class="album-view" wx:elif="{{currentView === 'album'}}">
    <view class="album-month" wx:for="{{album}}" wx:for-item="medias" wx:for-index="month" wx:key="month">
      <text class="month-title">{{month}} ({{medias.length}}张)</text>
      <view class="album-grid">
        <image class="album-image" wx:for="{{medias}}" wx:key="mediaId"
               src="{{item.fileUrl}}" mode="aspectFill"
               bindtap="previewImage" data-url="{{item.fileUrl}}"
               wx:if="{{item.mediaType === 'image'}}" />
      </view>
    </view>
    <view class="empty-state" wx:if="{{Object.keys(album).length === 0}}">
      <text class="empty-icon">📸</text>
      <text class="empty-title">还没有照片</text>
      <text class="empty-desc">记录生活中的美好瞬间吧</text>
    </view>
  </view>

  <!-- 浮动创建按钮 -->
  <view class="float-btn" bindtap="goToCreate">
    <text class="float-btn-icon">✏️</text>
  </view>
</view>
