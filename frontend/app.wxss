/* 全局样式 - 双人岛设计系统 */
page {
  --primary-color: #FF6B81;
  --primary-light: #FFA0B0;
  --primary-dark: #E8556B;
  --bg-color: #FFF8F8;
  --card-bg: #FFFFFF;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --border-color: #F0F0F0;
  --success-color: #52C41A;
  --warning-color: #FAAD14;
  --danger-color: #FF4D4F;

  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  color: var(--text-primary);
  box-sizing: border-box;
}

/* ===== 页面容器 ===== */
.page-container {
  min-height: 100vh;
  background: var(--bg-color);
  padding: 20rpx 30rpx;
}

/* ===== 通用卡片样式 ===== */
.card {
  background: var(--card-bg);
  border-radius: 48rpx;
  padding: 30rpx;
  margin: 20rpx 30rpx;
  box-shadow: 0 8rpx 48rpx rgba(0, 0, 0, 0.06);
}

/* ===== 内容卡片（无外边距，适合列表内使用） ===== */
.content-card {
  background: var(--card-bg);
  border-radius: 48rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 48rpx rgba(0, 0, 0, 0.06);
}

/* ===== Section 标题 ===== */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  display: block;
}

/* ===== 通用按钮 ===== */
.btn-primary {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  transition: opacity 0.3s;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background: white;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: 50rpx;
  padding: 22rpx 60rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
}

/* ===== 输入框 ===== */
.input-field {
  background: #F8F8F8;
  border: 2rpx solid var(--border-color);
  border-radius: 24rpx;
  padding: 24rpx 30rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: var(--primary-color);
}

/* ===== 浮动按钮 ===== */
.float-btn {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  font-weight: 300;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 129, 0.35);
  z-index: 50;
}

.float-btn:active {
  opacity: 0.85;
  transform: scale(0.95);
}

/* ===== 模态框 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 48rpx 48rpx 0 0;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
  padding: 40rpx 30rpx;
  padding-bottom: calc(120rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 32rpx;
  display: block;
}

.modal-input {
  background: #F8F8F8;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid var(--border-color);
  margin-bottom: 20rpx;
  min-height: 88rpx;
}

.modal-input:focus {
  border-color: var(--primary-color);
}

.modal-textarea {
  background: #F8F8F8;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid var(--border-color);
  min-height: 160rpx;
  margin-bottom: 20rpx;
}

.btn-submit {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
  border: none;
  border-radius: 50rpx;
  height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  width: 100%;
  margin-top: 20rpx;
}

.btn-submit:active {
  opacity: 0.85;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-state .empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  display: block;
}

.empty-state .empty-title {
  color: var(--text-secondary);
  font-size: 28rpx;
  display: block;
  text-align: center;
}

.empty-state .empty-desc {
  color: var(--text-light);
  font-size: 24rpx;
  margin-top: 12rpx;
  display: block;
  text-align: center;
}

.empty-state .empty-retry {
  margin-top: 30rpx;
  padding: 16rpx 48rpx;
  font-size: 26rpx;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: 30rpx;
  background: transparent;
}

/* ===== 骨架屏 ===== */
.skeleton-list {
  padding: 20rpx 30rpx;
}

.skeleton-card {
  background: white;
  border-radius: 48rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 48rpx rgba(0, 0, 0, 0.06);
}

.skeleton-line {
  height: 28rpx;
  background: linear-gradient(90deg, #F0F0F0 25%, #E8E8E8 50%, #F0F0F0 75%);
  background-size: 200% 100%;
  border-radius: 8rpx;
  animation: skeleton-shimmer 1.5s infinite;
  margin-bottom: 16rpx;
}

.skeleton-line:last-child {
  margin-bottom: 0;
}

.skeleton-line.w-60 { width: 60%; }
.skeleton-line.w-40 { width: 40%; }
.skeleton-line.w-80 { width: 80%; }
.skeleton-line.h-16 { height: 16rpx; }

@keyframes skeleton-shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ===== 错误状态 ===== */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.error-state .error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  display: block;
}

.error-state .error-text {
  color: var(--text-secondary);
  font-size: 28rpx;
  display: block;
  text-align: center;
  margin-bottom: 30rpx;
}

.error-state .error-retry {
  padding: 16rpx 48rpx;
  font-size: 26rpx;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: 30rpx;
  background: transparent;
}

/* ===== 列表筛选栏 ===== */
.filter-bar {
  display: flex;
  background: white;
  border-radius: 48rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  border-radius: 40rpx;
  font-weight: 500;
}

.filter-item.active {
  background: var(--primary-color);
  color: white;
}

/* ===== 分割线 ===== */
.divider-light {
  height: 2rpx;
  background: var(--border-color);
  margin: 24rpx 0;
}
